  "keyFeatures": [
    "SQL-like syntax (SELECT, WHERE, JOIN, GROUP BY, HAVING, ORDER BY, LIMIT) for querying structured files",
    "Supports XML, JSON, NDJSON, CSV, XLS/XLSX, ODS, YAML, and NEON file formats",
    "Stream-first processing for large files with low memory pressure",
    "Fluent PHP API and FQL string syntax for building queries",
    "Rich function library: string, math, date/time, array, hashing, and aggregate functions",
    "INNER, LEFT, RIGHT, and FULL JOINs across different file formats and sources",
    "EXPLAIN and EXPLAIN ANALYZE for query inspection and performance analysis",
    "UNION and UNION ALL for combining results from multiple queries",
    "INTO clause for exporting query results to files",
    "DTO (Data Transfer Object) mapping for typed result handling",
    "Custom function support via extensible base classes"
  ],
